report 50157 "Update 3PL Prep Codes"
{
    Caption = 'Update 3PL PREP Codes';
    ProcessingOnly = true;
    UsageCategory = Administration;
    ApplicationArea = All;

    dataset
    {
        dataitem(SalesHeader; "Sales Header")
        {
            DataItemTableView = where("Document Type" = const(Order),
                                      Status = filter(Open | Released));

            trigger OnAfterGetRecord()
            begin
                // Add your logic to determine the prep code
                // For example, based on customer, item, location, etc.
                if ShouldHavePrepCode(SalesHeader) then
                    SalesHeader."3PL PREP Code" := GetPrepCodeForOrder(SalesHeader);
                
                SalesHeader.Modify();
                UpdatedCount += 1;
            end;
        }
    }

    trigger OnPostReport()
    begin
        Message('Updated %1 sales orders with 3PL PREP Codes.', UpdatedCount);
    end;

    local procedure ShouldHavePrepCode(SalesHeader: Record "Sales Header"): Boolean
    begin
        // Add your business logic here
        // Return true if this order should have a prep code
        exit(true); // Or your specific condition
    end;

    local procedure GetPrepCodeForOrder(SalesHeader: Record "Sales Header"): Code[20]
    begin
        // Add your logic to determine the prep code
        // Examples:
        // - Based on customer
        // - Based on shipping method  
        // - Based on item categories
        // - Based on location
        exit('PREP001'); // Your default or calculated code
    end;

    var
        UpdatedCount: Integer;
}